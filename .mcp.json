{
  "mcpServers": {
    "better-t-stack": {
      "command": "pnpm",
      "args": ["dlx", "create-better-t-stack@latest", "mcp"]
    },
    "gbrain": {
      "command": "bun",
      "args": ["gbrain", "serve"],
      "env": {
        "GBRAIN_SOURCE": "perf-monorepo",
        "MCP_STDIO": "1"
      }
    }
  }
}
